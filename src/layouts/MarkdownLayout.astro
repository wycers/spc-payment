---
import Layout from '~/layouts/PageLayout.astro';

import type { MetaData } from '~/types';

export interface Props {
  frontmatter: {
    title?: string;
  };
}

const { frontmatter } = Astro.props;

const metadata: MetaData = {
  title: frontmatter?.title,
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl bg-[#080b12]">
    <h1 class="font-heading text-4xl font-semibold leading-tight tracking-normal text-white md:text-5xl">
      {frontmatter.title}
    </h1>
    <div
      class="mx-auto prose prose-lg max-w-4xl prose-invert prose-headings:font-heading prose-headings:font-semibold prose-headings:tracking-normal prose-headings:text-white prose-a:text-cyan-300 prose-p:text-slate-400 prose-li:text-slate-400 prose-strong:text-slate-100 mt-8"
    >
      <slot />
    </div>
  </section>
</Layout>
