---
import Layout from '~/layouts/PageLayout.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

const metadata = {
  title: 'Contact',
  description:
    'Contact SPC Pay to discuss Australia EFTPOS terminal, SDK, API, acquiring support, deployment, and after-sales support for payment devices, POS software, SaaS, and kiosks.',
};
---

<Layout metadata={metadata}>
  <section class="bg-[#080b12] px-4 pb-4 pt-16 sm:px-6 sm:pt-20">
    <div class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-200">Contact SPC Pay</p>
      <h1 class="mt-4 max-w-4xl text-4xl font-semibold tracking-normal text-white sm:text-6xl">
        Discuss your Australia payment integration
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-400">
        Share the product you are bringing to market, the customer segment you serve, and the payment flow you need to
        support. We will start with a practical review of fit and next steps.
      </p>
    </div>
  </section>

  <ContactForm
    id="form"
    eyebrow="Consultation"
    title="Book a consultation"
    subtitle="Share your project context, integration stage, and launch timeline. We focus on terminal deployment, SDK/API integration, local acquiring coordination, testing, and launch support."
  />
</Layout>
