---
import Layout from '~/layouts/PageLayout.astro';
import HeroVideo from '~/components/widgets/HeroVideo.astro';
import TrustBar from '~/components/widgets/TrustBar.astro';
import PainPoints from '~/components/widgets/PainPoints.astro';
import Solutions from '~/components/widgets/Solutions.astro';
import ProcessSteps from '~/components/widgets/ProcessSteps.astro';
import UseCases from '~/components/widgets/UseCases.astro';
import ComplianceSection from '~/components/widgets/ComplianceSection.astro';
import FAQ from '~/components/widgets/FAQ.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

const metadata = {
  title: 'SPC Pay — 澳洲收款接入支持',
  ignoreTitleTemplate: true,
  description:
    'SPC Pay 为支付设备厂商、POS 软件商、零售 SaaS 企业和 Kiosk 服务商提供澳洲本地 EFTPOS 终端、SDK/API 接入、测试、部署与上线支持。',
};
---

<Layout metadata={metadata}>
  <HeroVideo />
  <TrustBar />
  <PainPoints />
  <Solutions />
  <ProcessSteps />
  <UseCases />
  <ComplianceSection />
  <FAQ />
  <ContactForm
    title="准备把你的设备或软件接入澳洲收款？"
    subtitle="告诉我们你的产品类型、目标市场和当前接入阶段。我们会先确认项目适配度，再讨论终端、SDK、测试和上线支持路径。"
  />
</Layout>
