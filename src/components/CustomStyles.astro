---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(34 211 238);
    --aw-color-secondary: rgb(45 212 191);
    --aw-color-accent: rgb(59 130 246);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(148 163 184);
    --aw-color-text-page: rgb(248 250 252);
    --aw-color-bg-page: rgb(8 11 18);

    --aw-color-bg-page-dark: rgb(8 11 18);

    ::selection {
      background-color: rgb(34 211 238 / 28%);
      color: rgb(248 250 252);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(34 211 238);
    --aw-color-secondary: rgb(45 212 191);
    --aw-color-accent: rgb(59 130 246);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(148 163 184);
    --aw-color-text-page: rgb(248 250 252);
    --aw-color-bg-page: rgb(8 11 18);

    ::selection {
      background-color: rgb(34 211 238 / 28%);
      color: rgb(248 250 252);
    }
  }
</style>
