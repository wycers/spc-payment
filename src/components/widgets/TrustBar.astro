---
const items = ['本地收单协作', 'SDK/API 集成', '终端部署支持', '澳洲收款流程适配'];
---

<section class="border-y border-white/10 bg-[#080b12]">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-px px-4 py-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4">
    {
      items.map((item) => (
        <div class="flex min-h-14 items-center justify-center border-white/10 px-4 py-3 text-center text-sm font-medium text-slate-300 sm:[&:not(:nth-child(2n))]:border-r lg:[&:not(:last-child)]:border-r lg:[&:nth-child(2)]:border-r">
          {item}
        </div>
      ))
    }
  </div>
</section>
