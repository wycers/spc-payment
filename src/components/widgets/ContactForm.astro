---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}

const {
  id = 'contact',
  eyebrow = '联系我们',
  title = '预约咨询',
  subtitle = '告诉我们你的产品类型、目标市场和当前接入阶段。我们会先确认项目适配度，再讨论终端、SDK/API、测试和上线支持路径。',
} = Astro.props;

const productTypes = [
  { value: 'Payment terminal', label: '支付终端' },
  { value: 'POS software', label: 'POS 软件' },
  { value: 'SaaS', label: 'SaaS' },
  { value: 'Kiosk', label: 'Kiosk / 自助设备' },
  { value: 'Other', label: '其他' },
];

const targetMarkets = [
  { value: 'Australia', label: '澳洲' },
  { value: 'New Zealand', label: '新西兰' },
  { value: 'Other', label: '其他' },
];
---

<section id={id} class="bg-[#080b12] py-20 sm:py-28">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-200">{eyebrow}</p>
      <h2 class="mt-4 text-3xl font-semibold tracking-normal text-white sm:text-5xl">{title}</h2>
      <p class="mt-5 max-w-xl text-lg leading-8 text-slate-400">{subtitle}</p>
      <div class="mt-8 rounded-lg border border-white/10 bg-white/[0.04] p-5">
        <p class="text-sm leading-7 text-slate-400">
          首次沟通建议准备公司介绍、产品类型、目标商户场景、当前接入方式和预计上线时间表。
        </p>
      </div>
    </div>

    <form
      action="#"
      method="post"
      class="rounded-lg border border-white/10 bg-[#101827]/88 p-5 shadow-[0_1.5rem_5rem_rgb(0_0_0_/_0.26)] sm:p-6 lg:p-8"
    >
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="grid gap-2 text-sm font-medium text-slate-200">
          公司名称
          <input
            required
            type="text"
            name="company_name"
            autocomplete="organization"
            class="min-h-12 rounded-md border border-white/10 bg-white/[0.055] px-4 text-base text-white outline-none transition-[border-color,box-shadow] duration-200 placeholder:text-slate-500 focus:border-cyan-300/70 focus:shadow-[0_0_0_3px_rgb(34_211_238_/_0.16)]"
          />
        </label>

        <label class="grid gap-2 text-sm font-medium text-slate-200">
          联系人
          <input
            required
            type="text"
            name="contact_person"
            autocomplete="name"
            class="min-h-12 rounded-md border border-white/10 bg-white/[0.055] px-4 text-base text-white outline-none transition-[border-color,box-shadow] duration-200 placeholder:text-slate-500 focus:border-cyan-300/70 focus:shadow-[0_0_0_3px_rgb(34_211_238_/_0.16)]"
          />
        </label>

        <label class="grid gap-2 text-sm font-medium text-slate-200">
          邮箱
          <input
            required
            type="email"
            name="email"
            autocomplete="email"
            class="min-h-12 rounded-md border border-white/10 bg-white/[0.055] px-4 text-base text-white outline-none transition-[border-color,box-shadow] duration-200 placeholder:text-slate-500 focus:border-cyan-300/70 focus:shadow-[0_0_0_3px_rgb(34_211_238_/_0.16)]"
          />
        </label>

        <label class="grid gap-2 text-sm font-medium text-slate-200">
          WeChat / 电话
          <input
            type="text"
            name="wechat_phone"
            autocomplete="tel"
            class="min-h-12 rounded-md border border-white/10 bg-white/[0.055] px-4 text-base text-white outline-none transition-[border-color,box-shadow] duration-200 placeholder:text-slate-500 focus:border-cyan-300/70 focus:shadow-[0_0_0_3px_rgb(34_211_238_/_0.16)]"
          />
        </label>

        <label class="grid gap-2 text-sm font-medium text-slate-200">
          产品类型
          <select
            name="product_type"
            class="min-h-12 rounded-md border border-white/10 bg-[#121b2a] px-4 text-base text-white outline-none transition-[border-color,box-shadow] duration-200 focus:border-cyan-300/70 focus:shadow-[0_0_0_3px_rgb(34_211_238_/_0.16)]"
          >
            {productTypes.map(({ value, label }) => <option value={value}>{label}</option>)}
          </select>
        </label>

        <label class="grid gap-2 text-sm font-medium text-slate-200">
          目标市场
          <select
            name="target_market"
            class="min-h-12 rounded-md border border-white/10 bg-[#121b2a] px-4 text-base text-white outline-none transition-[border-color,box-shadow] duration-200 focus:border-cyan-300/70 focus:shadow-[0_0_0_3px_rgb(34_211_238_/_0.16)]"
          >
            {targetMarkets.map(({ value, label }) => <option value={value}>{label}</option>)}
          </select>
        </label>
      </div>

      <label class="mt-5 grid gap-2 text-sm font-medium text-slate-200">
        项目说明
        <textarea
          name="message"
          rows="5"
          class="min-h-36 rounded-md border border-white/10 bg-white/[0.055] px-4 py-3 text-base text-white outline-none transition-[border-color,box-shadow] duration-200 placeholder:text-slate-500 focus:border-cyan-300/70 focus:shadow-[0_0_0_3px_rgb(34_211_238_/_0.16)]"
        ></textarea>
      </label>

      <button type="submit" class="btn-primary mt-7 w-full">预约咨询</button>
    </form>
  </div>
</section>
